# MQTT
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_TOPIC=SHiBA-Plant01/#

# Database
DB_PATH=data/seedcare.db

# Email notification
PYTHON_SEND_EMAIL_ACCOUNT=your-gmail@gmail.com
PYTHON_SEND_EMAIL_PASSWORD=your-app-password
ALERT_EMAIL_TO=your-email@example.com

# Thresholds
LOW_THRESHOLD_TEMPERATURE=10.0
HIGH_THRESHOLD_TEMPERATURE=35.0
LOW_THRESHOLD_MOISTURE=30.0

# Timeout (seconds) - no message received alert
TIMEOUT_NO_MESSAGE=300

# Data retention (days)
RETENTION_DAYS=120

# Python path (for systemd)
PYTHONPATH=/opt/app/seedcare
