[Unit]
Description=SeedCare Dashboard (Streamlit)
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/opt/app/seedcare
EnvironmentFile=-/opt/app/seedcare/.env
ExecStart=/bin/bash -c 'PYTHONPATH=/opt/app/seedcare exec /opt/app/seedcare/.venv/bin/python seedcare/dashboard.py'
Restart=on-failure
RestartSec=5
Environment=PATH=/opt/app/seedcare/.venv/bin:/usr/local/bin:/usr/bin:/bin
Environment=PYTHONPATH=/opt/app/seedcare

[Install]
WantedBy=multi-user.target
